# Copy this file to `.env` and fill in your own credentials.
# `.env` is gitignored; this template is safe to commit.

# Supabase project credentials.
# Found in: Supabase dashboard -> Project Settings -> API.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Note: GEMINI_API_KEY is intentionally NOT in the client anymore.
# It now lives as a Supabase Edge Function secret. To set it (one time):
#   supabase functions deploy chat
#   supabase secrets set GEMINI_API_KEY=<your-key>
# The chat Edge Function reads it server-side; the client never sees it.
